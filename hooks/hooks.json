{
  "description": "桌面弹窗确认插件 - PreToolUse 时当需要用户确认则弹窗提醒",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/zhangyu/.claude/plugins/confirm-plugin/scripts/pre-tool-use.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
